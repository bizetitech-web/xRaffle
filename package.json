{
  "name": "xraffle",
  "version": "2.0.0",
  "scripts": {
    "start": "node server/server.js",
    "build": "cd client && npm install && npm run build",
    "migrate": "node server/scripts/migrate.js",
    "verify:db": "npm --prefix server run verify:db",
    "test:integration": "npm --prefix server run test:integration",
    "test:e2e": "npm --prefix client run e2e",
    "check:links": "node scripts/check-doc-links.mjs",
    "ci:quick": "npm run check:links && npm --prefix client run build && npm run test:integration",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "postinstall": "cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}